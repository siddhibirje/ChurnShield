 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 06 — Baseline & Ensemble Classification Models\n",
    "**Goal:** Train Logistic Regression, Decision Tree, Random Forest, XGBoost, LightGBM, and Voting Ensemble. Compare all on AUC-ROC, precision, recall, F1.\n",
    "\n",
    "**Note:** This notebook mirrors `train_models.py` in step-by-step format for presentation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys; sys.path.append('..')\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings; warnings.filterwarnings('ignore')\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.tree import DecisionTreeClassifier\n",
    "from sklearn.ensemble import RandomForestClassifier, VotingClassifier\n",
    "from sklearn.metrics import (classification_report, roc_auc_score, roc_curve,\n",
    "                              auc, confusion_matrix, ConfusionMatrixDisplay)\n",
    "from xgboost import XGBClassifier\n",
    "from lightgbm import LGBMClassifier\n",
    "\n",
    "df = pd.read_csv('../data/processed/cleaned_features.csv')\n",
    "print(f'Shape: {df.shape} | Churn: {df[\"Churn\"].mean():.2%}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Prepare Features ──────────────────────────────────\n",
    "DROP = ['customerID', 'Churn', 'tenure_group', 'RFM_Segment',\n",
    "        'recency', 'frequency', 'monetary', 'R_Score', 'F_Score', 'M_Score']\n",
    "X_raw = df.drop([c for c in DROP if c in df.columns], axis=1)\n",
    "y = df['Churn']\n",
    "\n",
    "X = pd.get_dummies(X_raw, drop_first=True)\n",
    "print(f'Features: {X.shape[1]}')\n",
    "\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X)\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_scaled, y, test_size=0.2, random_state=42, stratify=y\n",
    ")\n",
    "print(f'Train: {X_train.shape} | Test: {X_test.shape}')\n",
    "print(f'Train churn rate: {y_train.mean():.2%} | Test: {y_test.mean():.2%}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Helper: Evaluate Model ────────────────────────────\n",
    "results = {}\n",
    "\n",
    "def evaluate_model(name, model):\n",
    "    model.fit(X_train, y_train)\n",
    "    preds = model.predict(X_test)\n",
    "    proba = model.predict_proba(X_test)[:,1]\n",
    "    auc_score = roc_auc_score(y_test, proba)\n",
    "    report = classification_report(y_test, preds, output_dict=True)\n",
    "    results[name] = {\n",
    "        'AUC-ROC': round(auc_score, 4),\n",
    "        'Accuracy': round(report['accuracy'], 4),\n",
    "        'Precision (Churn)': round(report['1']['precision'], 4),\n",
    "        'Recall (Churn)': round(report['1']['recall'], 4),\n",
    "        'F1 (Churn)': round(report['1']['f1-score'], 4),\n",
    "    }\n",
    "    print(f\"[{name:25s}] AUC={auc_score:.4f} | F1={report['1']['f1-score']:.4f} | Recall={report['1']['recall']:.4f}\")\n",
    "    return model, proba"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Train All Models ──────────────────────────────────\n",
    "scale_pos = int((y==0).sum()/(y==1).sum())\n",
    "\n",
    "lr, prob_lr = evaluate_model('Logistic Regression',\n",
    "    LogisticRegression(C=1.0, max_iter=1000, random_state=42, class_weight='balanced'))\n",
    "\n",
    "dt, prob_dt = evaluate_model('Decision Tree',\n",
    "    DecisionTreeClassifier(max_depth=6, min_samples_split=30, random_state=42, class_weight='balanced'))\n",
    "\n",
    "rf, prob_rf = evaluate_model('Random Forest',\n",
    "    RandomForestClassifier(n_estimators=200, max_depth=10, random_state=42,\n",
    "                            class_weight='balanced', n_jobs=-1))\n",
    "\n",
    "xgb, prob_xgb = evaluate_model('XGBoost',\n",
    "    XGBClassifier(n_estimators=300, learning_rate=0.05, max_depth=6,\n",
    "                  scale_pos_weight=scale_pos, random_state=42,\n",
    "                  eval_metric='logloss', use_label_encoder=False, n_jobs=-1))\n",
    "\n",
    "lgbm, prob_lgbm = evaluate_model('LightGBM',\n",
    "    LGBMClassifier(n_estimators=300, learning_rate=0.05, max_depth=6,\n",
    "                   class_weight='balanced', random_state=42, n_jobs=-1, verbose=-1))\n",
    "\n",
    "voting = VotingClassifier([('rf',rf),('xgb',xgb),('lgbm',lgbm)], voting='soft', n_jobs=-1)\n",
    "voting_model, prob_voting = evaluate_model('Voting Ensemble', voting)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Results Table ──────────────────────────────────────\n",
    "results_df = pd.DataFrame(results).T\n",
    "results_df = results_df.sort_values('AUC-ROC', ascending=False)\n",
    "print('\\n📊 Model Comparison Table:')\n",
    "results_df.style.highlight_max(color='lightgreen').format('{:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── ROC Curves — All Models ───────────────────────────\n",
    "models_proba = {\n",
    "    'Logistic Regression': prob_lr, 'Decision Tree': prob_dt,\n",
    "    'Random Forest': prob_rf, 'XGBoost': prob_xgb,\n",
    "    'LightGBM': prob_lgbm, 'Voting Ensemble': prob_voting\n",
    "}\n",
    "colors = ['#6366f1','#f43f5e','#22c55e','#f59e0b','#06b6d4','#a78bfa']\n",
    "\n",
    "plt.figure(figsize=(9, 7))\n",
    "plt.plot([0,1],[0,1],'k--',linewidth=0.8,label='Random (AUC=0.50)')\n",
    "for (name, proba), color in zip(models_proba.items(), colors):\n",
    "    fpr, tpr, _ = roc_curve(y_test, proba)\n",
    "    plt.plot(fpr, tpr, label=f'{name} (AUC={auc(fpr,tpr):.3f})', color=color, linewidth=2)\n",
    "\n",
    "plt.xlabel('False Positive Rate', fontsize=11)\n",
    "plt.ylabel('True Positive Rate', fontsize=11)\n",
    "plt.title('ROC Curves — All Models', fontsize=13, fontweight='bold')\n",
    "plt.legend(loc='lower right', fontsize=9)\n",
    "plt.grid(alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Feature Importance (Random Forest) ───────────────\n",
    "feat_names = X.columns.tolist() if hasattr(X, 'columns') else [f'f{i}' for i in range(X_scaled.shape[1])]\n",
    "imps = rf.feature_importances_\n",
    "fi_df = pd.DataFrame({'Feature': feat_names, 'Importance': imps})\n",
    "fi_df = fi_df.sort_values('Importance').tail(15)\n",
    "\n",
    "plt.figure(figsize=(9, 6))\n",
    "plt.barh(fi_df['Feature'], fi_df['Importance'], color='#6366f1', edgecolor='white', alpha=0.85)\n",
    "plt.title('Top 15 Feature Importances (Random Forest)', fontweight='bold')\n",
    "plt.xlabel('Importance')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Save Models ────────────────────────────────────────\n",
    "import pickle, os\n",
    "os.makedirs('../models', exist_ok=True)\n",
    "\n",
    "for name, model in [('random_forest', rf), ('xgboost', xgb),\n",
    "                     ('lightgbm', lgbm), ('voting_ensemble', voting_model),\n",
    "                     ('logistic_regression', lr), ('decision_tree', dt)]:\n",
    "    with open(f'../models/{name}.pkl', 'wb') as f:\n",
    "        pickle.dump(model, f)\n",
    "\n",
    "with open('../models/scaler.pkl', 'wb') as f:\n",
    "    pickle.dump(scaler, f)\n",
    "\n",
    "feat_names_list = list(X.columns)\n",
    "with open('../models/feature_names.pkl', 'wb') as f:\n",
    "    pickle.dump(feat_names_list, f)\n",
    "\n",
    "# Best model\n",
    "best = max(results, key=lambda k: results[k]['AUC-ROC'])\n",
    "print(f'Best model: {best} (AUC={results[best][\"AUC-ROC\"]})')\n",
    "import shutil\n",
    "model_map = {'Random Forest':'random_forest','XGBoost':'xgboost','LightGBM':'lightgbm',\n",
    "             'Voting Ensemble':'voting_ensemble','Logistic Regression':'logistic_regression','Decision Tree':'decision_tree'}\n",
    "shutil.copy(f'../models/{model_map[best]}.pkl', '../models/best_model.pkl')\n",
    "print('✅ All models saved!')"
   ]
  }
 ],
